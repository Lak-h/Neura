// ─────────────────────────────────────────────────────────────────────────────
// NEURAXIS — Prisma Schema
//
// Local dev runs on SQLite so the project works with zero external services.
// Production should switch `provider` to "postgresql" and re-introduce native
// enums + pgvector for KBEmbedding.vector (see README → Deployment).
//
// SQLite cannot express Prisma enums, so enum-like fields are Strings and are
// validated by Zod at every boundary (see src/lib/validations/enums.ts).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────── AUTH ───────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  totpSecret    String?
  totpEnabled   Boolean   @default(false)
  lastSeenAt    DateTime?
  presence      String    @default("offline") // online | away | offline

  accounts      Account[]
  sessions      Session[]
  memberships   OrganisationMember[]
  teamMembers   TeamMember[]
  notifications Notification[]
  auditLogs     AuditLog[]
  messages      Message[]
  sentInvites   OrganisationInvite[] @relation("InviteSender")
  referralsMade Referral[]           @relation("Referrer")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  deviceLabel  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────── ORGS ───────────────────────────

model Organisation {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  logoUrl   String?
  plan      String  @default("starter") // starter | growth | scale | enterprise
  aiCredits Int     @default(10000)
  dataResidency String @default("US")   // US | EU | APAC

  members            OrganisationMember[]
  invites            OrganisationInvite[]
  subscription       Subscription?
  usageRecords       UsageRecord[]
  creditTransactions CreditTransaction[]
  agents             AIAgent[]
  workflows          Workflow[]
  knowledgeBases     KnowledgeBase[]
  conversations      Conversation[]
  conversationTags   ConversationTag[]
  integrations       Integration[]
  teams              Team[]
  auditLogs          AuditLog[]
  apiKeys            APIKey[]
  secrets            Secret[]
  notifications      Notification[]
  referrals          Referral[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
}

model OrganisationMember {
  id     String @id @default(cuid())
  orgId  String
  userId String
  role   String @default("member") // owner | admin | member | viewer

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, userId])
  @@index([userId])
  @@index([orgId])
}

model OrganisationInvite {
  id        String    @id @default(cuid())
  orgId     String
  email     String
  role      String    @default("member")
  token     String    @unique @default(cuid())
  invitedById String?
  acceptedAt DateTime?
  expiresAt DateTime

  org       Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy User?        @relation("InviteSender", fields: [invitedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, email])
  @@index([orgId])
  @@index([invitedById])
}

// ─────────────────────────── BILLING ───────────────────────────

model Subscription {
  id                   String    @id @default(cuid())
  orgId                String    @unique
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  plan                 String    @default("starter")
  status               String    @default("trialing") // trialing | active | past_due | canceled | paused
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeCustomerId])
}

model UsageRecord {
  id        String @id @default(cuid())
  orgId     String
  kind      String // ai_credits | storage_mb | api_calls
  amount    Int
  agentId   String?
  userId    String?
  metadata  String? // JSON

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, kind, createdAt])
}

model CreditTransaction {
  id          String @id @default(cuid())
  orgId       String
  delta       Int    // positive = top-up/grant, negative = consumption
  reason      String // subscription_grant | top_up | agent_usage | workflow_usage | referral_bonus | adjustment
  balanceAfter Int
  stripePaymentIntentId String?

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, createdAt])
}

// ─────────────────────────── AI AGENTS ───────────────────────────

model AIAgent {
  id           String  @id @default(cuid())
  orgId        String
  name         String
  description  String?
  avatarUrl    String?
  systemPrompt String
  model        String  @default("claude-sonnet-4-6")
  temperature  Float   @default(0.7)
  maxTokens    Int     @default(4096)
  topP         Float   @default(1)
  frequencyPenalty Float @default(0)
  persona      String  @default("formal") // formal | casual | technical | empathetic
  toolsJson    String  @default("[]")     // JSON array of enabled tool ids
  status       String  @default("draft")  // draft | active | archived
  confidenceThreshold Float @default(0.6) // below this → human review

  org           Organisation     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  versions      AgentVersion[]
  deployments   AgentDeployment[]
  analytics     AgentAnalytics[]
  conversations Conversation[]
  kbLinks       KnowledgeBase[]  @relation("AgentKnowledge")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([orgId, status])
}

model AgentVersion {
  id        String @id @default(cuid())
  agentId   String
  version   Int
  snapshot  String // full JSON snapshot of agent config at save time
  changelog String?

  agent AIAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, version])
  @@index([agentId])
}

model AgentDeployment {
  id       String  @id @default(cuid())
  agentId  String
  channel  String  // widget | slack | email | api | whatsapp
  config   String  @default("{}") // JSON channel config
  isActive Boolean @default(true)
  publicKey String @unique @default(cuid()) // embed/widget key

  agent AIAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId, channel])
}

model AgentAnalytics {
  id                String @id @default(cuid())
  agentId           String
  date              DateTime
  messagesSent      Int    @default(0)
  conversationCount Int    @default(0)
  avgResponseMs     Int    @default(0)
  satisfactionScore Float?
  errorCount        Int    @default(0)
  creditsUsed       Int    @default(0)

  agent AIAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, date])
  @@index([agentId, date])
}

// ─────────────────────────── WORKFLOWS ───────────────────────────

model Workflow {
  id          String  @id @default(cuid())
  orgId       String
  name        String
  description String?
  status      String  @default("draft") // draft | active | paused | archived
  version     Int     @default(1)
  isTemplate  Boolean @default(false)
  isPublished Boolean @default(false) // marketplace listing
  triggerType String  @default("manual") // webhook | schedule | email | form | db_change | stripe_event | manual
  cronExpr    String?

  org   Organisation   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  nodes WorkflowNode[]
  edges WorkflowEdge[]
  runs  WorkflowRun[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([orgId, status])
}

model WorkflowNode {
  id         String @id @default(cuid())
  workflowId String
  type       String // trigger | action | ai | condition | delay | loop
  subtype    String // e.g. send_email, http_request, summarise, if_else …
  label      String
  config     String @default("{}") // JSON
  positionX  Float  @default(0)
  positionY  Float  @default(0)

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowId])
}

model WorkflowEdge {
  id           String  @id @default(cuid())
  workflowId   String
  sourceNodeId String
  targetNodeId String
  branchLabel  String? // for condition nodes: "true" | "false" | case name

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowId])
}

model WorkflowRun {
  id         String    @id @default(cuid())
  workflowId String
  status     String    @default("running") // running | success | failed | cancelled
  triggeredBy String   @default("manual")
  inputJson  String    @default("{}")
  outputJson String?
  error      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  workflow Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  logs     WorkflowRunLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowId, status, createdAt])
}

model WorkflowRunLog {
  id        String  @id @default(cuid())
  runId     String
  nodeId    String?
  level     String  @default("info") // info | warn | error
  message   String
  inputJson String?
  outputJson String?
  durationMs Int?

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([runId])
}

// ─────────────────────────── KNOWLEDGE ───────────────────────────

model KnowledgeBase {
  id          String  @id @default(cuid())
  orgId       String
  name        String
  description String?
  visibility  String  @default("org") // org | team | private

  org       Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  documents KBDocument[]
  agents    AIAgent[]    @relation("AgentKnowledge")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([orgId])
}

model KBDocument {
  id        String  @id @default(cuid())
  kbId      String
  title     String
  sourceType String @default("editor") // editor | pdf | docx | txt | url | import
  sourceUrl String?
  content   String  @default("") // Tiptap JSON or extracted text
  parentId  String? // hierarchical pages
  status    String  @default("ready") // processing | ready | failed

  kb       KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade)
  parent   KBDocument?   @relation("DocTree", fields: [parentId], references: [id], onDelete: SetNull)
  children KBDocument[]  @relation("DocTree")
  chunks   KBChunk[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([kbId])
  @@index([parentId])
}

model KBChunk {
  id         String @id @default(cuid())
  documentId String
  index      Int
  text       String
  tokenCount Int    @default(0)

  document  KBDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embedding KBEmbedding?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documentId, index])
  @@index([documentId])
}

model KBEmbedding {
  id      String @id @default(cuid())
  chunkId String @unique
  model   String @default("text-embedding-3-small")
  // SQLite dev: JSON-serialised float array. Postgres prod: switch to pgvector.
  vector  String

  chunk KBChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────── INBOX ───────────────────────────

model Conversation {
  id        String  @id @default(cuid())
  orgId     String
  agentId   String?
  channel   String  @default("widget") // email | widget | slack | whatsapp | playground
  subject   String?
  status    String  @default("open") // open | pending | resolved | archived
  priority  String  @default("normal") // low | normal | high | urgent
  sentiment String? // positive | neutral | negative
  csatScore Int?
  assigneeId String?
  summary   String?
  needsHumanReview Boolean @default(false)
  slaDueAt  DateTime?
  externalCustomerEmail String?

  org      Organisation      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agent    AIAgent?          @relation(fields: [agentId], references: [id], onDelete: SetNull)
  messages Message[]
  tags     ConversationTag[] @relation("ConvTags")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([orgId, status])
  @@index([agentId])
  @@index([assigneeId])
}

model Message {
  id             String  @id @default(cuid())
  conversationId String
  role           String  // user | assistant | system | human_agent | internal_note
  content        String
  authorId       String? // human author (team member) if applicable
  confidence     Float?
  latencyMs      Int?
  creditsUsed    Int     @default(0)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([authorId])
}

model ConversationTag {
  id    String @id @default(cuid())
  orgId String
  name  String
  color String @default("#6366f1")

  org           Organisation   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversations Conversation[] @relation("ConvTags")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, name])
}

// ─────────────────────────── INTEGRATIONS ───────────────────────────

model Integration {
  id        String  @id @default(cuid())
  orgId     String
  provider  String  // salesforce | hubspot | slack | gmail | google_drive | jira | …
  status    String  @default("connected") // connected | error | disconnected
  config    String  @default("{}") // JSON: tokens (encrypted), field mappings
  lastSyncAt DateTime?
  errorCount Int    @default(0)

  org    Organisation       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  events IntegrationEvent[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([orgId, provider])
  @@index([orgId])
}

model IntegrationEvent {
  id            String @id @default(cuid())
  integrationId String
  direction     String @default("inbound") // inbound | outbound
  eventType     String
  payload       String @default("{}")
  status        String @default("success") // success | failed
  error         String?

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([integrationId, createdAt])
}

// ─────────────────────────── TEAMS ───────────────────────────

model Team {
  id          String  @id @default(cuid())
  orgId       String
  name        String
  description String?
  avatarUrl   String?

  org     Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members TeamMember[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([orgId, name])
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  role   String @default("member") // lead | member

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
  @@index([userId])
}

// ─────────────────────────── PLATFORM ───────────────────────────

model Notification {
  id      String  @id @default(cuid())
  userId  String
  orgId   String?
  kind    String  // mention | invite | billing | workflow | agent | system
  title   String
  body    String?
  href    String?
  readAt  DateTime?

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, readAt])
  @@index([orgId])
}

model AuditLog {
  id        String  @id @default(cuid())
  orgId     String
  userId    String?
  action    String  // e.g. agent.create, member.invite, billing.upgrade
  targetType String?
  targetId  String?
  ipAddress String?
  userAgent String?
  metadata  String? // JSON

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, createdAt])
  @@index([userId])
}

model APIKey {
  id         String    @id @default(cuid())
  orgId      String
  name       String
  hashedKey  String    @unique
  keyPrefix  String    // first 8 chars shown in UI: "nrx_live_a1b2…"
  lastUsedAt DateTime?
  revokedAt  DateTime?

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model Secret {
  id             String @id @default(cuid())
  orgId          String
  name           String
  encryptedValue String // AES-256-GCM, key from env SECRETS_ENCRYPTION_KEY
  iv             String
  authTag        String

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, name])
}

// ─────────────────────────── CONTENT / GROWTH ───────────────────────────

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  contentMdx  String
  coverImage  String?
  authorName  String
  publishedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([publishedAt])
}

model Changelog {
  id          String   @id @default(cuid())
  version     String   @unique
  title       String
  contentMdx  String
  publishedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Referral {
  id           String    @id @default(cuid())
  orgId        String
  referrerId   String
  code         String    @unique @default(cuid())
  redeemedByEmail String?
  redeemedAt   DateTime?
  creditAwarded Int      @default(0)

  org      Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  referrer User         @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([referrerId])
}

model WaitlistEntry {
  id      String  @id @default(cuid())
  email   String  @unique
  company String?
  source  String?
  invitedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
